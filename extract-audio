#!/usr/bin/env bash

set -euo pipefail

if [ "$#" -ne 2 ] && ([ "$#" -ne 1 ] || [ "$1" != "--help" ]); then
  echo "Extracts the audio stream from a video file and saves it in the desired audio format."
  echo "Usage: extract-audio <input-video> <output-audio>"
  exit 1
fi

INPUT="$1"
OUTPUT="$2"

if [ ! -f "$INPUT" ]; then
  echo "Error: Input file does not exist: $INPUT"
  exit 1
fi

EXT="${OUTPUT##*.}"
EXT_LOWER=$(echo "$EXT" | tr '[:upper:]' '[:lower:]')

# Detect if input has an audio stream
if ! ffprobe -v error -select_streams a -show_entries stream=index -of csv=p=0 "$INPUT" | grep -q .; then
  echo "Error: No audio stream found in input."
  exit 1
fi

echo "Extracting audio from: $INPUT → $OUTPUT"

# Strategy:
# 1. If output is same codec/container → stream copy (fast, lossless)
# 2. Else → high-quality re-encode

case "$EXT_LOWER" in
  aac|m4a)
    ffmpeg -y -i "$INPUT" \
      -vn -map a:0 \
      -c:a aac -b:a 192k \
      -movflags +faststart \
      "$OUTPUT"
    ;;
  mp3)
    ffmpeg -y -i "$INPUT" \
      -vn -map a:0 \
      -c:a libmp3lame -q:a 0 \
      "$OUTPUT"
    ;;
  wav)
    ffmpeg -y -i "$INPUT" \
      -vn -map a:0 \
      -c:a pcm_s16le \
      "$OUTPUT"
    ;;
  flac)
    ffmpeg -y -i "$INPUT" \
      -vn -map a:0 \
      -c:a flac \
      "$OUTPUT"
    ;;
  *)
    echo "Unknown extension .$EXT → defaulting to high-quality AAC"
    ffmpeg -y -i "$INPUT" \
      -vn -map a:0 \
      -c:a aac -b:a 192k \
      "$OUTPUT"
    ;;
esac

echo "Done."